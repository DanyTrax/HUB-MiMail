# App
NODE_ENV=development
APP_PORT=3000
API_PORT=4000

# Database
POSTGRES_DB=hub_migracion
POSTGRES_USER=hub_user
POSTGRES_PASSWORD=change_me
# Puerto en host (cambia si 5432 esta ocupado)
POSTGRES_PORT=55432

# Redis
# Puerto en host (cambia si 6379 esta ocupado)
REDIS_PORT=56379

# Security
JWT_SECRET=change_me
ENCRYPTION_KEY=change_me_32_chars_min
CORS_ORIGIN=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# Microsoft OAuth2
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
MS_REDIRECT_URI=http://localhost:4000/auth/microsoft/callback

# Docker images (future use)
BACKEND_IMAGE=hub-migracion-backend
WORKER_IMAGE=hub-migracion-worker
FRONTEND_IMAGE=hub-migracion-frontend
